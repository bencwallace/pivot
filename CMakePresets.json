{
    "version": 3,
    "configurePresets": [{
        "name": "debug",
        "displayName": "Debug",
        "binaryDir": "build",
        "cacheVariables": {
            "CMAKE_BUILD_TYPE": "Debug",
            "GLIBC_DEBUG": "OFF"
        }
    }, {
        "name": "test",
        "displayName": "Test",
        "binaryDir": "build",
        "cacheVariables": {
            "CMAKE_BUILD_TYPE": "Debug",
            "CMAKE_CXX_COMPILER": "clang++",
            "SANITIZE": "ON",
            "GLIBC_DEBUG": "ON"
        }
    }, {
        "name": "profile",
        "displayName": "Profile",
        "binaryDir": "build",
        "cacheVariables": {
            "CMAKE_BUILD_TYPE": "Debug",
            "CMAKE_CXX_FLAGS": "-fno-omit-frame-pointer",
            "GLIBC_DEBUG": "OFF",
            "SANITIZE": "OFF"
        }
    }, {
        "name": "release",
        "displayName": "Release",
        "binaryDir": "build",
        "cacheVariables": {
            "CMAKE_BUILD_TYPE": "Release"
        }
    }],
    "buildPresets": [{
        "name": "debug",
        "displayName": "Debug",
        "configurePreset": "debug",
        "configuration": "Debug",
        "targets": ["all", "test_pivot", "pivot_exec"]
    }, {
        "name": "test",
        "displayName": "Test",
        "configurePreset": "test",
        "configuration": "Debug",
        "targets": ["test_pivot"]
    }, {
        "name": "profile",
        "displayName": "Profile",
        "configurePreset": "profile",
        "configuration": "RelWithDebInfo",
        "targets": ["pivot_exec"]
    }, {
        "name": "release",
        "displayName": "Release",
        "configurePreset": "release",
        "configuration": "Release",
        "targets": ["all", "test_pivot", "pivot_exec"]
    }]
}